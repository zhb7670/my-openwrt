CONFIG_PACKAGE_kmod-nf-conntrack6=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-nf-nat6=y
CONFIG_PACKAGE_kmod-nf-ipvs=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-fullcone=y
CONFIG_PACKAGE_kmod-ipt-conntrack=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-tproxy=y
CONFIG_PACKAGE_kmod-ipt-ipset=y
CONFIG_PACKAGE_kmod-crypto-core=y
CONFIG_PACKAGE_kmod-crypto-aead=y
CONFIG_PACKAGE_kmod-crypto-sha256=y
CONFIG_PACKAGE_kmod-crypto-sha512=y
CONFIG_PACKAGE_kmdo-crypto-gcm=y

# 游戏加速
CONFIG_PACKAGE_uugamebooster=y
CONFIG_PACKAGE_leigod-acc=y

# 广告过滤
CONFIG_PACKAGE_adbyby=y
CONFIG_PACKAGE_koolproxy=y

# 网易云音乐解锁
CONFIG_PACKAGE_UnblockNeteaseMusic=y
CONFIG_PACKAGE_UnblockNeteaseMusic-Go=y

# 激活服务器
CONFIG_PACKAGE_vlmcsd=y

# 其他应用
CONFIG_PACKAGE_appfilter=y
CONFIG_PACKAGE_ddnsto=y
CONFIG_PACKAGE_gecoosac=y
CONFIG_PACKAGE_pgyvpn=y
CONFIG_PACKAGE_phtunnel=y

# 编译优化
CONFIG_DEVEL=y
CONFIG_CCACHE=y
CONFIG_TARGET_OPTIMIZATION="-O2 -pipe -march=x86-64"
